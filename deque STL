#include <iostream>
#include <deque>
#include <vector>

using namespace std;

void printKMax(int arr[], int n, int k) {
    deque<int> dq;
    
    for (int i = 0; i < n; i++) {
        // 1. Remove elements out of this window
        if (!dq.empty() && dq.front() <= i - k) {
            dq.pop_front();
        }

        // 2. Remove elements smaller than the current element
        while (!dq.empty() && arr[i] >= arr[dq.back()]) {
            dq.pop_back();
        }

        // 3. Add current element's index
        dq.push_back(i);

        // 4. Print max for the window (starts after k-1 elements)
        if (i >= k - 1) {
            cout << arr[dq.front()] << (i == n - 1 ? "" : " ");
        }
    }
    cout << endl;
}

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n, k;
        cin >> n >> k;
        int arr[n];
        for (int i = 0; i < n; i++) {
            cin >> arr[i];
        }
        printKMax(arr, n, k);
    }
    return 0;
}
